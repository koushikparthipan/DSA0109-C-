#include <iostream>
using namespace std;

int main() {
    long long n;
    cin >> n;

    if (n <= 1) {
        cout << "NOT PERFECT";
        return 0;
    }

    long long sum = 1; 

    for (long long i = 2; i * i <= n; i++) {
        if (n % i == 0) {
            sum += i;
            long long other = n / i;
            if (other != i) sum += other;
        }
    }

    if (sum == n)
        cout << "PERFECT";
    else
        cout << "NOT PERFECT";

    return 0;
}
